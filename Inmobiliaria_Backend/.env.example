# ============================================================
# OpenAI
# ============================================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# HighLevel
# ============================================================
# Opcional: secreto compartido con HighLevel para validar el webhook.
# Si lo configuras, también debes mandarlo en el header X-Webhook-Secret
# desde el nodo Webhook de HighLevel.
HIGHLEVEL_WEBHOOK_SECRET=

# Private Integration Token (PIT) de HighLevel.
# Settings → Private Integrations → scopes mínimos:
#   conversations.write, conversations/message.write
HIGHLEVEL_API_TOKEN=pit-...

# Location/sub-cuenta de HighLevel donde está el WhatsApp.
# Lo encuentras en Settings → Business Profile, o en la URL del CRM.
LOCATION_ID=

# ============================================================
# Google Sheets
# ============================================================
# Hay DOS formas de pasar las credenciales (usá UNA, no las dos):
#
# 1) DEV LOCAL: ruta a un archivo JSON en disco.
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
#
# 2) PRODUCCIÓN (Docker/EasyPanel): contenido completo del JSON en una sola
#    línea. Para generarlo:
#       cat service-account.json | jq -c .
#    Pegá el resultado acá. Tiene prioridad sobre GOOGLE_SERVICE_ACCOUNT_FILE.
GOOGLE_SERVICE_ACCOUNT_JSON=

# La service account debe tener acceso de lectura al sheet (compartirlo con su email).
# ID del Google Sheet (la parte entre /d/ y /edit en la URL).
SHEET_ID=

# ============================================================
# PostgreSQL (Supabase)
# ============================================================
# En Supabase → Project Settings → Database tienes dos opciones:
#   1) "Direct connection"  (host db.<ref>.supabase.co, puerto 5432)
#   2) "Connection pooling" (host aws-X-XX.pooler.supabase.com, puerto 6543 transaction / 5432 session)
# Para este backend (con su propio pool psycopg) la "Direct connection" o el
# pooler en Session mode (5432) son las opciones más simples.
DB_USER=postgres
DB_PASSWORD=
DB_HOST=db.xxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres

# ============================================================
# Admin UI (login propio + React)
# ============================================================
# Usuario y contraseña inicial del admin. SOLO se usan la primera vez para
# crear el registro en la tabla inmobiliaria_admin_users. Después de eso,
# si cambias estos valores no afecta la contraseña ya guardada.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Secret aleatorio para firmar los JWT del admin (HS256).
# OBLIGATORIO: genera el tuyo, NO uses este placeholder en producción.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_JWT_SECRET=CHANGE_ME_run_python_secrets_token_urlsafe_48

# Tiempo de vida del JWT del admin en horas (default: 24)
ADMIN_JWT_TTL_HOURS=24

# Lista CSV de orígenes permitidos para CORS (frontend en dev y prod).
# Ejemplo: http://localhost:5173,https://admin-inmobiliaria.vercel.app
CORS_ALLOWED_ORIGINS=

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
